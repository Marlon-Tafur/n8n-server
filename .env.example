# ============================================================
# n8n Server — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. cp .env.example .env
#   2. Edita .env con tus valores reales
#   3. Ejecuta ./scripts/init-secrets.sh para generar passwords
#   4. NUNCA commitees .env
#
# NOTA: Los secretos (passwords, encryption keys) NO van aquí.
#       Van en archivos dentro de ./secrets/ (ver init-secrets.sh)
# ============================================================

# --- Proyecto ---
PROJECT_NAME=n8n-server
TZ=America/Lima
GENERIC_TIMEZONE=America/Lima

# --- Dominios ---
# Editor protegido con Cloudflare Access
N8N_EDITOR_HOST=n8n.tudominio.com
# Webhooks públicos (con WAF, sin Access)
N8N_WEBHOOK_HOST=hooks.tudominio.com

# --- n8n ---
# Para desarrollo usa "latest". Para producción fija versión.
# Ejemplo producción: n8nio/n8n:1.94.1
N8N_IMAGE=n8nio/n8n:latest
N8N_PROTOCOL=https
N8N_PORT=5678

# --- n8n URLs ---
N8N_EDITOR_BASE_URL=https://${N8N_EDITOR_HOST}
WEBHOOK_URL=https://${N8N_WEBHOOK_HOST}/

# --- n8n Seguridad (hardening) ---
N8N_SECURE_COOKIE=true
N8N_SAMESITE_COOKIE=lax
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_BLOCK_FILE_ACCESS_TO_N8N_FILES=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RESTRICT_FILE_ACCESS_TO=/files
N8N_PROXY_HOPS=1

# Bloquea nodos peligrosos que permiten ejecución de comandos
# o acceso al filesystem del host.
NODES_EXCLUDE=["n8n-nodes-base.executeCommand","n8n-nodes-base.readWriteFile","n8n-nodes-base.localFileTrigger"]

# --- n8n Ejecuciones (pruning) ---
# Sin esto, la tabla de ejecuciones crece indefinidamente.
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true

# --- n8n Binarios ---
# Guarda archivos grandes en disco, no en PostgreSQL.
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_BINARY_DATA_STORAGE_PATH=/files/binaryData

# --- n8n Privacidad ---
N8N_DIAGNOSTICS_ENABLED=false
N8N_HIRING_BANNER_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=true
N8N_TEMPLATES_ENABLED=true
N8N_PUBLIC_API_DISABLED=false

# --- n8n Métricas ---
N8N_METRICS=true
N8N_LOG_LEVEL=info

# --- PostgreSQL ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
# La password NO va aquí. Va en: ./secrets/postgres_password.txt

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=tu-token-del-tunnel-aqui

# --- IA local (opcional, para --profile ai) ---
OLLAMA_BASE_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333

# --- IA externa (opcional) ---
# Estas keys las usas dentro de n8n como credenciales,
# no necesitan estar aquí. Solo si usas el meta-workflow.
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# --- Backups ---
BACKUP_RETENTION_DAYS=30
